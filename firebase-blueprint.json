{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered user of the Smart Material Recommender system",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "The user's display name" },
        "email": { "type": "string", "format": "email", "description": "The user's Gmail address" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of account creation" },
        "verified": { "type": "boolean", "description": "Whether the user has verified their email" }
      },
      "required": ["username", "email", "createdAt", "verified"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of registered users"
    }
  }
}
